# =============================================================================
# TIMING CONSTRAINTS
# =============================================================================
# Primary 60 MHz input clock (Period = 1.667 ns)
NET "clk_60mHz" TNM_NET = "TNM_IN_CLK";
TIMESPEC "TS_IN_CLK" = PERIOD "TNM_IN_CLK" 1.6667 ns HIGH 50%;

# =============================================================================
# PHYSICAL PIN CONSTRAINTS (Spartan-6 XC6SLX4-TQG144)
# =============================================================================

# --- System Clock ---
# FIXED: Uncommented to ensure the FPGA receives the primary clock signal
NET "clk_60mHz"            LOC = "P55"  | IOSTANDARD = LVCMOS33; # 60 MHz Oscillator

# --- SPI Chip Select Lines ---
NET "spi_stm32_nss_p"      LOC = "P48"  | IOSTANDARD = LVCMOS33; # CS Polling (misc0)
#NET "spi_stm32_nss_d"      LOC = "P50"  | IOSTANDARD = LVCMOS33; # CS DMA (misc2)

# --- SPI Shared Data Bus (Runtime Communication) ---
NET "spi_stm32_mosi"       LOC = "P64"  | IOSTANDARD = LVCMOS33; # MOSI (Flash DQ0)
NET "spi_stm32_miso"       LOC = "P65"  | IOSTANDARD = LVCMOS33; # MISO (Flash DQ1 / FPGA_MISO2)

# --- SPI Shared Clock Input (Jumper) ---
NET "spi_stm32_sck"        LOC = "P47"  | IOSTANDARD = LVCMOS33; # SCK (misc1)
NET "spi_stm32_sck"        CLOCK_DEDICATED_ROUTE = FALSE;

# --- Global Hardware Interrupt to STM32 (Active Low) ---
NET "fpga_2_stm32_interrupt_N" LOC = "P51" | IOSTANDARD = LVCMOS33; # Goes to EXTI3 (PC3) on STM32

# --- FCS Discrete Input Buffer Enables (Active Low) ---
NET "OE_DR[0]"             LOC = "P126" | IOSTANDARD = LVCMOS33;
NET "OE_DR[1]"             LOC = "P124" | IOSTANDARD = LVCMOS33;

# --- FCS Discrete Inputs ---
NET "DR[0]"                LOC = "P142" | IOSTANDARD = LVCMOS33;
NET "DR[1]"                LOC = "P141" | IOSTANDARD = LVCMOS33;
NET "DR[2]"                LOC = "P140" | IOSTANDARD = LVCMOS33;
NET "DR[3]"                LOC = "P139" | IOSTANDARD = LVCMOS33;
NET "DR[4]"                LOC = "P138" | IOSTANDARD = LVCMOS33;
NET "DR[5]"                LOC = "P137" | IOSTANDARD = LVCMOS33;
NET "DR[6]"                LOC = "P134" | IOSTANDARD = LVCMOS33;
NET "DR[7]"                LOC = "P133" | IOSTANDARD = LVCMOS33;
NET "DR[8]"                LOC = "P132" | IOSTANDARD = LVCMOS33;
NET "DR[9]"                LOC = "P131" | IOSTANDARD = LVCMOS33;
NET "DR[10]"               LOC = "P127" | IOSTANDARD = LVCMOS33;

NET "HEF"                  LOC = "P123" | IOSTANDARD = LVCMOS33;
NET "APDS"                 LOC = "P121" | IOSTANDARD = LVCMOS33;
NET "HEAT"                 LOC = "P120" | IOSTANDARD = LVCMOS33;
NET "MG"                   LOC = "P119" | IOSTANDARD = LVCMOS33;
NET "GM"                   LOC = "P118" | IOSTANDARD = LVCMOS33;
NET "CC"                   LOC = "P117" | IOSTANDARD = LVCMOS33;
NET "DC"                   LOC = "P116" | IOSTANDARD = LVCMOS33;
NET "SET_R"                LOC = "P115" | IOSTANDARD = LVCMOS33;
NET "RESET_R"              LOC = "P114" | IOSTANDARD = LVCMOS33;
NET "BC_EN"                LOC = "P112" | IOSTANDARD = LVCMOS33;
NET "RL"                   LOC = "P111" | IOSTANDARD = LVCMOS33;
NET "WS"                   LOC = "P94"  | IOSTANDARD = LVCMOS33;
NET "PSCC"                 LOC = "P105" | IOSTANDARD = LVCMOS33;
NET "K1"                   LOC = "P101" | IOSTANDARD = LVCMOS33;
NET "BTN_CANNON"           LOC = "P99"  | IOSTANDARD = LVCMOS33;
NET "RST_FILTR"            LOC = "P98"  | IOSTANDARD = LVCMOS33;
NET "UR"                   LOC = "P93"  | IOSTANDARD = LVCMOS33;
NET "REM"                  LOC = "P88"  | IOSTANDARD = LVCMOS33;
NET "SCF_ON"               LOC = "P104" | IOSTANDARD = LVCMOS33;
NET "SCF_ON_ADD"           LOC = "P102" | IOSTANDARD = LVCMOS33;

# --- FCS Control Outputs (Discrete Outputs from STM32 Write Register) ---
NET "ENA_SHOOTING"         LOC = "P1"   | IOSTANDARD = LVCMOS33; # Bit 0: Enable Shooting
NET "GMEE"                 LOC = "P6"   | IOSTANDARD = LVCMOS33; # Bit 1: Missile Elevation Output
NET "RANGE_OVER_1280"      LOC = "P2"   | IOSTANDARD = LVCMOS33; # Bit 2: Target Range > 1280m
NET "UOI"                  LOC = "P5"   | IOSTANDARD = LVCMOS33; # Bit 3: UOI Signal
NET "INHIBIT_SHOOTING"     LOC = "P24"  | IOSTANDARD = LVCMOS33; # Bit 4: Inhibit Shooting Command
NET "WIND_SENSOR_ON"       LOC = "P21"  | IOSTANDARD = LVCMOS33; # Bit 5: Enable Wind Sensor
NET "RFU4"                 LOC = "P22"  | IOSTANDARD = LVCMOS33; # Bit 6: Reserved for Future Use 4
NET "RFU5"                 LOC = "P23"  | IOSTANDARD = LVCMOS33; # Bit 7: Reserved for Future Use 5

# --- Flash Lockout Line ---
NET "w25q128_nss"          LOC = "P38"  | IOSTANDARD = LVCMOS33; # Flash CS on Pin 38 (cso)

# --- debug ---
NET "led[0]"               LOC = "P16"  | IOSTANDARD = LVCMOS33; # VD35 (Green)
NET "led[1]"               LOC = "P27"  | IOSTANDARD = LVCMOS33; # VD36 (Yellow)
NET "led[2]"               LOC = "P29"  | IOSTANDARD = LVCMOS33; # VD37 (Red)

# --- Diagnostic Test Points (TP[7:5]) ---
# FIXED: Reordered to match the physical assignments in msb_main.v
NET "tp[5]"                LOC = "P79"  | IOSTANDARD = LVCMOS33; # TP5 on P79 (Programmable Pulse Output)
NET "tp[6]"                LOC = "P80"  | IOSTANDARD = LVCMOS33; # TP6 on P80 (1 kHz Reference Clock)
NET "tp[7]"                LOC = "P81"  | IOSTANDARD = LVCMOS33; # TP7 on P81 (Sync Reset Status)